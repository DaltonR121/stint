{
  "name": "stint-vscode",
  "displayName": "Stint Time Tracker",
  "description": "Shows your current Stint time tracking status in the VS Code status bar.",
  "version": "0.3.0",
  "publisher": "mosaic-ridge",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/DaltonR121/stint"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Stint",
      "properties": {
        "stint.apiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:7653",
          "description": "URL of the Stint local API server."
        },
        "stint.pollInterval": {
          "type": "number",
          "default": 3000,
          "description": "How often to poll the Stint API (milliseconds)."
        },
        "stint.stintPath": {
          "type": "string",
          "default": "stint",
          "description": "Path to the stint binary (auto-starts the server if not running)."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "package": "pnpm exec vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "pnpm": {
    "overrides": {
      "undici": "^7.28.0",
      "tmp": "^0.2.6",
      "lodash": "^4.18.0",
      "form-data": "^4.0.6",
      "fast-uri": "^3.1.2",
      "markdown-it": "^14.2.0",
      "js-yaml": "^4.2.0",
      "qs": "^6.15.2",
      "picomatch": "^2.3.2",
      "uuid": "^11.1.1"
    }
  }
}
